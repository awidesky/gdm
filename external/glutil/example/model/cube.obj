# Cube with per-face UVs (0-1)
mtllib cube.mtl
o Cube_TexturePerFace
usemtl Material_cube_no_texture
s off

v 1.000000 -1.000000 -1.000000
v 1.000000 -1.000000 1.000000
v -1.000000 -1.000000 1.000000
v -1.000000 -1.000000 -1.000000
v 1.000000 1.000000 -1.000000
v 1.000000 1.000000 1.000000
v -1.000000 1.000000 1.000000
v -1.000000 1.000000 -1.000000

vt 0.000000 0.000000
vt 1.000000 0.000000
vt 1.000000 1.000000
vt 0.000000 1.000000

vn 0.000000 0.000000 -1.000000
vn -1.000000 0.000000 0.000000
vn 0.000000 0.000000 1.000000
vn 1.000000 0.000000 0.000000
vn 0.000000 1.000000 0.000000
vn 0.000000 -1.000000 0.000000

f 1/1/1 4/2/1 8/3/1
f 1/1/1 8/3/1 5/4/1

f 4/1/2 3/2/2 7/3/2
f 4/1/2 7/3/2 8/4/2

f 2/1/3 3/2/3 7/3/3
f 2/1/3 7/3/3 6/4/3

f 1/1/4 5/2/4 6/3/4
f 1/1/4 6/3/4 2/4/4

f 5/1/5 8/2/5 7/3/5
f 5/1/5 7/3/5 6/4/5

f 1/1/6 2/2/6 3/3/6
f 1/1/6 3/3/6 4/4/6
